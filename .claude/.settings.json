{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(pnpm run:*)",
      "Bash(pnpm ci)",
      "Bash(npx tsc:*)",
      "Bash(npx next *)",
      "Read",
      "Edit"
    ],
    "ask": ["Bash(git push:*)", "WebFetch"],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Bash(cat .env:*)",
      "Bash(rm -rf:*)"
    ]
  }
}
